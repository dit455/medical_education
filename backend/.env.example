# Copy this file to .env (and fill in real values) or export these as
# environment variables before running the Flask app. None of these are
# read automatically from a .env file unless you load one yourself
# (e.g. with python-dotenv) - db.py reads them via os.environ with the
# defaults shown below.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Mysql@123
DB_NAME=medical

# Seeded into the `users` table on first run if no Super Admin row exists yet
# (see routes/auth.py:ensure_super_admin). Change these before deploying.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=Admin@123
